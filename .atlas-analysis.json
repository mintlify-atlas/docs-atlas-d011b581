  "keyFeatures": [
    "Supports a wide variety of video and audio formats via FFmpeg",
    "Highly configurable via command-line options and config files",
    "Lua and JavaScript scripting API for extending player functionality",
    "JSON IPC protocol for external control of the player",
    "libmpv C API for embedding in other applications",
    "Hardware-accelerated video decoding (VDPAU, VAAPI, NVDEC, etc.)",
    "GPU-accelerated video rendering with shader support (gpu-next/gpu VO)",
    "On-Screen Controller (OSC) for mouse-based control",
    "Subtitle rendering and synchronization support",
    "Cross-platform: Linux, Windows, macOS"
  ],
  "publicApiSurface": [
    "mpv [options] [file|URL|PLAYLIST|-]",
    "--vo=<driver> (video output: gpu-next, gpu, xv, null, ...)",
    "--ao=<driver> (audio output: alsa, pulse, coreaudio, wasapi, ...)",
    "--vf=<filter-chain> (video filters)",
    "--af=<filter-chain> (audio filters)",
    "--script=<path> (load Lua/JS script)",
    "--input-ipc-server=<socket> (JSON IPC control socket)",
    "libmpv C API: mpv_create(), mpv_initialize(), mpv_command(), mpv_set_property(), mpv_get_property(), mpv_wait_event()",
    "Lua scripting: mp.command(), mp.get_property(), mp.set_property(), mp.observe_property(), mp.add_key_binding()",
    "JavaScript scripting: mp.command(), mp.get_property(), mp.set_property(), mp.observe_property()"
  ]
